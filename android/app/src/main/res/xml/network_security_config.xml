<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Prefer HTTPS. Cleartext only for known Kapunter hosts if a legacy asset still uses http. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">kapunter.com</domain>
    </domain-config>
</network-security-config>
